( // Start of uniteste.0 content
  { // The object to be returned by this module
    descrever: (nomeSuite, funcaoBlocoTestes) => (
      // 'funcaoBlocoTestes' is the user's lambda: (testar) => [ testar(...), ... ]
      // 'testar_na_suite' is created here by partially applying the inlined _testar logic
      funcaoBlocoTestes(
        (nomeTeste, assercaoFn) => ( // This is the 'testar_na_suite' function
          { // This is the inlined _testar logic, returns a test result object
            suite: nomeSuite,
            teste: nomeTeste,
            status: assercaoFn() == 1 ? "passou" : "falhou",
            mensagem: ""
          }
        )
      )
    )
  }
) // End of uniteste.0 content
